# reflect — environment variables (template, NOT a real .env)
# Copy this to .env and fill in your actual key:
#   cp .env.example .env

# ─── Required ────────────────────────────────────────────────────────

# Anthropic API key for Opus 4.7 calls.
# Get one at: https://console.anthropic.com / https://platform.claude.com
# Format: sk-ant-...
ANTHROPIC_API_KEY=<paste-your-anthropic-api-key-here>

# ─── Optional (with defaults) ────────────────────────────────────────

# Model to use for reflection. Default: claude-opus-4-7
# REFLECT_MODEL=claude-opus-4-7

# Effort level for adaptive thinking. low | medium | high | xhigh
# Default: high. xhigh recommended for coding/agentic but ~30% more cost.
# REFLECT_EFFORT=high

# Trigger threshold (sum of signal weights in last 10 tool calls).
# Default: 2.4. Lower = more sensitive. Raise to 3.0+ to reduce false triggers.
# REFLECT_TRIGGER_THRESHOLD=2.4

# Cooldown after trigger (turns to suppress next trigger).
# Default: 5
# REFLECT_COOLDOWN_TURNS=5

# Enable opt-in session log (.reflect/session-log.jsonl, 168h ephemeral).
# Default: 0 (disabled). Set to 1 to enable.
# REFLECT_LOG_ENABLED=0

# Debug logging to stderr.
# Default: 0
# REFLECT_DEBUG=0

# Disable reflect entirely for current session (escape hatch).
# Default: unset
# REFLECT_DISABLED=1
