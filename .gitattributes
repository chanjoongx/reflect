# Default: let git auto-detect + normalize line endings
* text=auto

# Shell scripts must be LF so bash can execute them on any platform
*.sh text eol=lf

# PowerShell scripts: CRLF is fine on Windows; LF works too
*.ps1 text eol=crlf

# Source files: LF (TypeScript / JavaScript / JSON / YAML / MD)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf

# Binary-like files (no line conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.mp4 binary
*.mov binary
*.zip binary
*.tar.gz binary

# Lock files: keep verbatim
package-lock.json -diff
pnpm-lock.yaml -diff
yarn.lock -diff
