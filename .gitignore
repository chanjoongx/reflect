# ===================================================================
# reflect — .gitignore
# Layer 1 of PII / secret defense. Layer 2 = .git/hooks/pre-commit
# (PII pattern scanner, cloned from stetkeep). Layer 3 = memory files
# physically located outside this repo.
#
# IMPORTANT: git .gitignore syntax does NOT support inline comments.
# All comments must be on their own line.
# ===================================================================

# Secrets — never commit
.env
.env.local
.env.*.local
*.key
*.pem
secrets.json
.credentials/

# API / runtime artifacts (session-guidance.md + session-log.jsonl, ephemeral)
.reflect/

# Internal docs (PII + strategy) — local only
CLAUDE.md
hackathon/

# Legacy paths (already moved to hackathon/, safety net)
docs/HACKATHON.md
docs/NEXT_SESSION.md

# Scratch
NOTES.md
TODO.md
SCRATCH.md

# Dependencies
node_modules/
# NOTE: package-lock.json IS committed (CI uses `npm ci` for reproducibility)
pnpm-lock.yaml
yarn.lock

# Build / output
dist/
build/
.next/
coverage/
*.tsbuildinfo

# Claude Code runtime state — user-local, NOT committed
# (settings.example.json IS committed as template)
.claude/settings.json
.claude/settings.local.json
.claude/local-settings.json
.claude/todos/
.claude/cache/
.claude/history/
.claude/*.log
.claude/*.lock
.claude/scheduled_tasks.lock

# OS
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Python (if any tooling added later)
__pycache__/
*.pyc
.venv/
venv/

# Backups + merge artifacts
*.backup-*
*.orig
*.rej

# reflect ablation outputs (committed selectively, raw runs ignored)
experiments/runs/
experiments/*.raw.json
# Internal methodology: task prompts + payloads (results in ablation-with-without.md, ablation-components.md are public)
experiments/ablation-*-task-prompt.md
experiments/payloads/

# Claude Code scheduled task state (user-local)
.claude/scheduled_tasks.json

# Claude Code conversation transcripts (safety net — normally at ~/.claude/projects/, but if repo-local .claude/projects/ created, contains PII: user prompts + Claude responses)
.claude/projects/

# npm artifacts + auth tokens
*.tgz
.npm/
.npmrc

# /web/ — localhost-only Next.js viewer (do NOT deploy)
web/node_modules/
web/.next/
web/out/
web/.vercel/
web/.env
web/.env.local
web/.env.*.local
web/next-env.d.ts
web/tsconfig.tsbuildinfo
web/.turbo/
